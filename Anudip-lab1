import java.util.Scanner;

public class maxNumber {
    public static void main(String[] args) {

        Scanner sc = new Scanner(System.in);

        System.out.print("Enter first number : " );
        double num1 = sc.nextDouble();

        System.out.print(" Enter second number : ");
        double num2 = sc.nextDouble();

        if(num1 > num2){
            System.out.print("the maximum between " + num1 +  " and " + num2 + " is : " + num1);
        }else{
            System.out.print("the maximum between " + num1 + " and " + num2 + " is : " + num2);
        }
    }
}

#Q3 Write a program to declare two variables num and n 

import java.util.Scanner;

public class bitChecker {

        public static void main(String[] args) {

            Scanner sc = new Scanner(System.in);

            System.out.print("Enter number : ");
            int num = sc.nextInt();

            System.out.print("Enter number position : ");
            int n = sc.nextInt();

            int bitStatus = (num >> n) & 1;


            if (bitStatus == 1) {
                System.out.println("The " + n + "th bit of " + num + " is set (1).");
            } else {
                System.out.println("The " + n + "th bit of " + num + " is not set (0).");
            }
        }
    }

