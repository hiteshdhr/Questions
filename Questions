## Q . Write a program that takes three sides of a triangle and

checks:-

-       If it is a valid triangle or not

-       If valid, classify if it is equilateral ,

isosceles or scalene

-    Also check if it is right angled triangle or notimport java.util.Scanner;

import java.util.Scanner;

public class triangle {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        System.out.print("Enter side a : ");
        int a = sc.nextInt();

        System.out.print("Enter side b : ");
        int b = sc.nextInt();

        System.out.print("Enter side c : ");
        int c = sc.nextInt();

        if(a + b > c && b + c > a && a + c > b ) {
            if (a == b && b == c) {
                System.out.print("It is a equilateral triangle.");
            } else if (a == b || b == c || c == a) {
                System.out.println("It is a isosceles triangle.");
            }else {
                System.out.println("It is a scalene Triangle.");
            }if((a*a + b*b == c * c) || (a*a + c*c == b*b) || (c*c + b*b == a*a)){
                System.out.print("It is a right angle triangle.");
            }
        }


    }
}

